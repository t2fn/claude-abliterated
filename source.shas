# source.shas — Pinned SHAs for all source repositories.
#
# These SHAs are reviewed and pinned. When a repo is updated,
# update the SHA here and re-run the build.
#
# To reset a SHA to dynamic HEAD:
#   unset <SHA_NAME>
# To force dynamic HEAD for all:
#   export FORCE_LS=1

