# EditorConfig helps maintain consistent coding styles across editors and IDEs
# Matches biome.json, .prettierrc, and eslint.config.mjs settings

root = true

[*]
charset          = utf-8
end_of_line      = lf
indent_style     = space
indent_size      = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.ts]
insert_final_newline = true
trim_trailing_whitespace = true

[*.tsx]
insert_final_newline = true
trim_trailing_whitespace = true

[*.js]
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_size      = 2

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size      = 2

[Makefile]
indent_style     = tab

[.prettierrc]
indent_size      = 2
