{
  "$schema": "https://biomejs.dev/schemas/0.3.3/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": { "noUnusedVariables": "warn", "useArrayLiterals": "warn" },
      "suspicious": { "noExplicitAny": "warn", "noConsole": "info" },
      "style": { "useConst": "error", "noNonNullAssertion": "warn" },
      "complexity": { "noForEach": "off" },
      "nursery": { "useSortedClasses": "warn" }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5",
      "semicolons": false,
      "arrowParentheses": "asNeeded",
      "quoteStyle": "single"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": false
    }
  }
}
