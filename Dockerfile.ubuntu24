# Dockerfile.ubuntu24 — Claude Code container on Ubuntu 24.04 (Noble)
#
# Base:      Ubuntu 24.04 Noble (glibc-based, familiar to Ubuntu users)
# Package:   apt / dpkg
# Node.js:   24 LTS via NodeSource DEB
# User:      claudeuser (non-root, recommended for security)
#
# Build args (passed from build_all.sh / build_*.sh):
#   CLAUDE_VERSION, TWEAKCC_SHA, LOBOTOMIZED_SHA, CLAUDE_TOOLS_SHA,
#   AWESOME_TOOLKIT_SHA, SUPERPOWERS_SHA, SHANNON_SHA
#
# Two layers:
#   1. Privileged run layer — all installs as root: apt-get, Node.js, npm, ollama
#   2. Unprivileged run layer — runs as claudeuser: CLI, tools, skills

FROM ubuntu

ARG CLAUDE_VERSION=latest \
    TWEAKCC_SHA=HEAD \
    LOBOTOMIZED_SHA=HEAD \
    CLAUDE_TOOLS_SHA=HEAD \
    AWESOME_TOOLKIT_SHA=HEAD \
    SUPERPOWERS_SHA=HEAD \
    SHANNON_SHA=HEAD

ENV CLAUDE_VERSION=$CLAUDE_VERSION \
    TWEAKCC_SHA=$TWEAKCC_SHA \
    LOBOTOMIZED_SHA=$LOBOTOMIZED_SHA \
    CLAUDE_TOOLS_SHA=$CLAUDE_TOOLS_SHA \
    AWESOME_TOOLKIT_SHA=$AWESOME_TOOLKIT_SHA \
    SUPERPOWERS_SHA=$SUPERPOWERS_SHA \
    SHANNON_SHA=$SHANNON_SHA

ENV PATH="/home/claudeuser/bin:/home/claudeuser/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Privileged run layer — root.  Everything is installed and updated in one pass:
# apt-get update, NodeSource nodejs, npm install+update, ollama, user creation.
# npm install --force avoids EEXIST conflicts; --force on npm update avoids
# symlink errors.  antigravity-awesome-skills installed alongside pnpm.
RUN apt-get update && \
    { apt-get install -y --no-install-recommends curl rsync git zstd coreutils ca-certificates gzip jq bc vim-common grep gawk sed tar findutils zip binutils strace valgrind lsof gdb ltrace p7zip-full socat gpg docker-cli wget file musl-tools bzip2 xz-utils unzip gcc-arm-none-eabi squashfs-tools; } && \
    update-ca-certificates && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource.gpg.key | gpg --dearmor -o /etc/apt/trusted.gpg.d/nodesource.gpg && \
    echo "deb [trusted=yes] https://deb.nodesource.com/node_24.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/* && \
    npm install -g --force pnpm antigravity-awesome-skills && \
    npm update -g --force && \
    npm update -g npm && \
    curl -fsSL https://ollama.com/install.sh | sh || true && \
    rm -rf /var/lib/apt/lists/* && \
    useradd -ms /bin/bash claudeuser

# Unprivileged run layer — claudeuser.  Copies install.sh and runs it to install
# the Claude CLI and all git-cloned tools.
COPY start_claude.sh /usr/bin/

USER claudeuser
WORKDIR /home/claudeuser

COPY install.sh /tmp/install.sh
RUN /bin/bash /tmp/install.sh

ENV BASH_DEFAULT_TIMEOUT_MS=3600000 BASH_MAX_TIMEOUT_MS=3600000 CLAUDE_CODE_FORK_SUBAGENT=1 CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 OLLAMA_CONTEXT_LENGTH=262144 CLAUDE_CONFIG_DIR=/workdir/.claude DISABLE_AUTOUPDATE=1 DISABLE_TELEMETRY=1 DISABLE_ERROR_REPORTING=1 DISABLE_BUG_COMMAND=1 CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 DISABLE_NON_ESSENTIAL_MODEL_CALLS=1 CLAUDE_CODE_ENABLE_TELEMETRY=0 OTEL_METRICS_EXPORTER=custom OTEL_TRACES_EXPORTER=none OTEL_LOGS_EXPORTER=none

WORKDIR /workdir

ENTRYPOINT ["start_claude.sh"]
